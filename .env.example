# BilldDesk 环境配置文件
# 复制此文件为 .env 并修改配置

# 开发服务器端口
VITE_DEV_PORT=5173

# API 基础地址
VITE_API_BASE_URL=https://api.desk.hsslive.cn

# WebSocket 地址
VITE_WS_URL=wss://ws.desk.hsslive.cn

# 是否使用私有化部署
VITE_USE_PRIVATIZE_DEPLOY=false

# 私有化部署 API 地址
VITE_PRIVATIZE_API_URL=

# 私有化部署 WebSocket 地址
VITE_PRIVATIZE_WS_URL=

# 调试模式
VITE_DEBUG=false

# 版本号
VITE_APP_VERSION=0.0.1
